###############################################################################
# GlobalFoundries 22nm - Generate Timing NDM
###############################################################################

# -----------------------------------------------------------------------------
# PDK root
# -----------------------------------------------------------------------------

set PDK "/asic/ip/DesignWare_logic_libs/globalfoundaries22nhsp/32hd116/hdl/lvt/2.00a"

# -----------------------------------------------------------------------------
# Library name
# -----------------------------------------------------------------------------

set LIBNAME "gf22nspllogl32hdl116f"

# -----------------------------------------------------------------------------
# Technology file (.tf)
# -----------------------------------------------------------------------------

set TECH_FILE \
"/asic/pdk/globalfoundries/22FDX-PLUS/V1.0_3.4/PlaceRoute/ICC2/Techfiles/10M_2Mx_4Cx_2Bx_2Jx_LB/22FDSOI_10M_2Mx_4Cx_2Bx_2Jx_LB_104cpp_12t_mw.tf"

# -----------------------------------------------------------------------------
# Liberty databases
# -----------------------------------------------------------------------------

set DB_DIR \
"$PDK/liberty/logic_synth_lvf"

# -----------------------------------------------------------------------------
# Physical frame library
# -----------------------------------------------------------------------------

set FRAME_LIB \
"$PDK/ndm/${LIBNAME}_frame_only.ndm"

###############################################################################
# Create workspace
###############################################################################

puts ""
puts "========================================"
puts "Creating workspace..."
puts "========================================"

create_workspace \
    -scale_factor 1000 \
    $LIBNAME \
    -flow normal \
    -technology $TECH_FILE

###############################################################################
# Read frame library
###############################################################################

puts ""
puts "========================================"
puts "Reading frame library..."
puts "========================================"

read_ndm -view frame $FRAME_LIB

###############################################################################
# Read Liberty timing libraries
###############################################################################

puts ""
puts "========================================"
puts "Reading Liberty databases..."
puts "========================================"

foreach db_file [lsort [glob $DB_DIR/*.db]] {

    set name [file rootname [file tail $db_file]]

    set process_label \
        [string range $name [expr {[string length "${LIBNAME}_"]}] end]

    puts ""
    puts "Reading:       $db_file"
    puts "Process label: $process_label"

    read_db \
        -process_label $process_label \
        $db_file
}

###############################################################################
# Check workspace
###############################################################################

puts ""
puts "========================================"
puts "Checking workspace..."
puts "========================================"

check_workspace -details all

###############################################################################
# Commit workspace
###############################################################################

puts ""
puts "========================================"
puts "Generating timing NDM..."
puts "========================================"

commit_workspace \
    -force \
    -output ${LIBNAME}_frame_timing_ccs.ndm

###############################################################################
# Done
###############################################################################

puts ""
puts "========================================"
puts "Workspace successfully committed!"
puts ""
puts "Generated:"
puts "    ${LIBNAME}_frame_timing_ccs.ndm"
puts "========================================"
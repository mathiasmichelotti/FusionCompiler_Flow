###############################################################################
# GlobalFoundries 22nm - Generate Timing NDM
###############################################################################

# -----------------------------------------------------------------------------
# PDK root
# -----------------------------------------------------------------------------

set PDK    "/asic/ip/DesignWare_logic_libs/globalfoundaries12lp/IN12LP_SC7P5T_84CPP_BASE_SSC14R_FDK/RELV00R60"
set PDK_TF "/asic/ip/DesignWare_logic_libs/globalfoundaries12lp/IN12LP_SC7P5T_84CPP_BASE_SSC14R_FDK/RELV00R60/ndm/tf"

# -----------------------------------------------------------------------------
# Library name
# -----------------------------------------------------------------------------

set LIBNAME "IN12LP_SC7P5T_84CPP_BASE_SSC14R"

# -----------------------------------------------------------------------------
# Technology file (.tf)
# -----------------------------------------------------------------------------

set TECH_FILE \
"$PDK_TF/12LP_9M_3Mx_4Cx_2Gx_LB_7p5t_84cpp_ndm.tf"

# -----------------------------------------------------------------------------
# Liberty databases
# -----------------------------------------------------------------------------

set DB_DIR \
"$PDK/model/timing/db"

# -----------------------------------------------------------------------------
# Physical frame library
# -----------------------------------------------------------------------------

set FRAME_LIB \
"$PDK/ndm/9M_3Mx_4Cx_1Gx_1Ox_LB/${LIBNAME}_frame_only.ndm"

###############################################################################
# Create workspace
###############################################################################

puts ""
puts "========================================"
puts "Creating workspace..."
puts "========================================"

create_workspace \
    -scale_factor 1000 \
    $LIBNAME \
    -flow normal \
    -technology $TECH_FILE

###############################################################################
# Read frame library
###############################################################################

puts ""
puts "========================================"
puts "Reading frame library..."
puts "========================================"

read_ndm -view frame $FRAME_LIB

###############################################################################
# Read Liberty timing libraries
###############################################################################

puts ""
puts "========================================"
puts "Reading Liberty databases..."
puts "========================================"

foreach db_file [lsort [glob $DB_DIR/*.db]] {

    set name [file rootname [file tail $db_file]]

    set process_label \
        [string range $name [expr {[string length "${LIBNAME}_"]}] end]

    puts ""
    puts "Reading:       $db_file"
    puts "Process label: $process_label"

    read_db \
        -process_label $process_label \
        $db_file
}

###############################################################################
# Check workspace
###############################################################################

puts ""
puts "========================================"
puts "Checking workspace..."
puts "========================================"

check_workspace -details all

###############################################################################
# Commit workspace
###############################################################################

puts ""
puts "========================================"
puts "Generating timing NDM..."
puts "========================================"

commit_workspace \
    -force \
    -output ${LIBNAME}_frame_timing_ccs.ndm

###############################################################################
# Done
###############################################################################

puts ""
puts "========================================"
puts "Workspace successfully committed!"
puts ""
puts "Generated:"
puts "    ${LIBNAME}_frame_timing_ccs.ndm"
puts "========================================"